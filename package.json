{
  "name": "garden-of-eatin-web",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "build:steps": "next build",
    "build": "NODE_ENV=production dotenvx run -f .env.production -- yarn run build:steps",
    "migrate": "NODE_ENV=development dotenvx run -f .env.development -- tsx ./prisma/migrations/index.ts",
    "dev": "NODE_ENV=development dotenvx run -f .env.development -- next dev",
    "start": "NODE_ENV=production dotenvx run -f .env.production -- next start",
    "lint": "biome check",
    "format": "biome format --write",
    "postinstall": "NODE_ENV=production dotenvx run -f .env.production -- prisma generate"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/material-nextjs": "^7.3.8",
    "@prisma/client": "6.x.x",
    "@react-email/components": "^1.0.8",
    "axios": "^1.14.0",
    "lodash": "^4.17.23",
    "next": "16.1.6",
    "next-mdx-remote": "^6.0.0",
    "nodemailer": "^8.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "spacetime": "^7.12.0",
    "suncalc": "^1.9.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/lodash": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/suncalc": "^1",
    "babel-plugin-react-compiler": "1.0.0",
    "prisma": "6.x.x",
    "prisma-zod-generator": "1.32.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "packageManager": "yarn@4.12.0+sha512.f45ab632439a67f8bc759bf32ead036a1f413287b9042726b7cc4818b7b49e14e9423ba49b18f9e06ea4941c1ad062385b1d8760a8d5091a1a31e5f6219afca8"
}
