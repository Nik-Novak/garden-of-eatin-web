enum TravelMode {
  Walking
  Cycling
  Driving
}
type DeviceSettings {
  travel_mode                   TravelMode?
}

model Device {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  uuid                      String              @unique

  settings                  DeviceSettings
  device_agreements         DeviceAgreement[]

  user                      User?              @relation(fields: [user_id], references: [id])
  user_id                   String?            @db.ObjectId

  meal_interactions         MealInteraction[] @relation(fields: [], references: [])

  bugs                      Bug[]
  contact_requests          ContactRequest[]
  reviews                   Review[]

  submitted_meals           Meal[]
  meal_occurrence_searches  MealOccurrenceSearch[]
  
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  @@map("devices")
}