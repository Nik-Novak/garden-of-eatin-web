enum TravelMode {
  Walking
  Cycling
  Driving
}
type DeviceSettings {
  travel_mode                   TravelMode?
}

enum DeviceType {
  UNKNOWN
  PHONE
  TABLET
  TV
  DESKTOP
}

type DeviceMetadata {
  app_version     String?
  app_build       String?
  brand           String?
  manufacturer    String?
  model_name      String?
  os_name         String?
  os_version      String?
  os_build_id     String?
  total_memory    Int?
  device_type     DeviceType?
  is_device       Boolean?
}

model Device {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  uuid                      String              @unique

  metadata                  DeviceMetadata?

  settings                  DeviceSettings
  device_agreements         DeviceAgreement[]

  user                      User?              @relation(fields: [user_id], references: [id])
  user_id                   String?            @db.ObjectId

  meal_interactions         MealInteraction[] @relation(fields: [], references: [])

  bugs                      Bug[]
  contact_requests          ContactRequest[]
  reviews                   Review[]

  submitted_meals           Meal[]
  meal_occurrence_searches  MealOccurrenceSearch[]
  
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  @@map("devices")
}